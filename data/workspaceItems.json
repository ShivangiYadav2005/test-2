[{"id":"42ce6e55-c6de-4a93-9de5-428f7601271a","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"note","x":-263.477,"y":-258.87,"width":415.648,"height":160,"zIndex":13,"createdAt":1777544091341,"updatedAt":1777544099069,"data":{"type":"note","content":"<p><b style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\">Measurement</b><span style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif; background-color: rgba(230, 241, 251, 0.094);\">&nbsp;— The process of comparing an unknown quantity with a known fixed standard (unit). The result tells how many times the standard fits into the quantity.</span></p>","color":"#dbeafe","sourceExcerpt":"1.1.2 Units and the Concept of Measurement","sourcePageNumber":3}},{"id":"90abd8c2-8718-47aa-9196-8141f8d925bc","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"note","x":-69.1521,"y":-667.459,"width":539.513,"height":338.453,"zIndex":1777544189013,"createdAt":1777544189008,"updatedAt":1777544201756,"data":{"type":"note","content":"<p style=\"margin: 4px 0px 8px; line-height: 1.65; color: rgb(194, 192, 182); font-family: &quot;Anthropic Sans&quot;, sans-serif;\"><b>Classification of Physical Quantities:</b></p><div class=\"compare\" style=\"margin: 8px 0px 0px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif; font-size: medium;\"><div class=\"cbox\" style=\"padding: 10px 12px; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 8px; font-size: 13px; line-height: 1.6;\"><span style=\"margin: 0px 0px 4px; display: block; color: rgb(250, 249, 245);\">Scalar Quantities</span>Only magnitude<br>Examples: mass, temperature, speed, distance, time, energy</div><div class=\"cbox\" style=\"padding: 10px 12px; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 8px; font-size: 13px; line-height: 1.6;\"><span style=\"margin: 0px 0px 4px; display: block; color: rgb(250, 249, 245);\">Vector Quantities</span>Magnitude + direction<br>Examples: velocity, displacement, force, acceleration, momentum</div></div><div class=\"compare\" style=\"margin: 10px 0px 0px; display: grid; grid-template-columns: 1fr 1fr; gap: 10px; color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif; font-size: medium;\"><div class=\"cbox\" style=\"padding: 10px 12px; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 8px; font-size: 13px; line-height: 1.6;\"><span style=\"margin: 0px 0px 4px; display: block; color: rgb(250, 249, 245);\">Fundamental (Base)</span>Cannot be expressed in terms of others<br>7 in SI: length, mass, time, current, temp, amount, luminous intensity</div><div class=\"cbox\" style=\"padding: 10px 12px; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 8px; font-size: 13px; line-height: 1.6;\"><span style=\"margin: 0px 0px 4px; display: block; color: rgb(250, 249, 245);\">Derived</span>Combinations of fundamental<br>Examples: velocity (L/T), force (MLT⁻²), energy (ML²T⁻²)</div></div>","color":"yellow","sourceExcerpt":null,"sourcePageNumber":null}},{"id":"9921eb53-bd4e-4980-a55c-22ba37e22652","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"line","x":-254.08712500000001,"y":-508.23249999999996,"width":194.935025,"height":43.11046874999994,"zIndex":1777544206071,"createdAt":1777544206071,"updatedAt":1777544206531,"data":{"type":"line","fromItemId":"3e8f8e18-6bea-4819-9fd0-67e8c086feb8","fromAnchor":"right","toItemId":"7c30ac5b-1c75-4fb4-ac27-d21ee4141f45","toAnchor":"left","points":[{"x":10,"y":33.11046874999994},{"x":184.935025,"y":10}],"color":"#64748b","strokeWidth":2,"style":"solid","arrowHead":false}},{"id":"a69abd59-966f-4463-aab1-ddb1528c6c4d","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"note","x":-277.874,"y":62.8519,"width":371.047,"height":160,"zIndex":19,"createdAt":1777544121597,"updatedAt":1777544129947,"data":{"type":"note","content":"<p><b style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\">Unit</b><span style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif; background-color: rgba(230, 241, 251, 0.094);\">&nbsp;— A conventionally accepted standard of reference. Must be: well-defined, easily reproducible, internationally accepted, invariant with time/place/conditions.</span></p>","color":"#dbeafe","sourceExcerpt":"1.1.3 Need for Measurement","sourcePageNumber":3}},{"id":"c692c0f2-97fd-4f5d-b806-5ce8d545281d","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"note","x":-250.506,"y":304.445,"width":697.817,"height":653.341,"zIndex":1777544206085,"createdAt":1777544266903,"updatedAt":1777544386286,"data":{"type":"note","content":"<table style=\"margin: 8px 0px 0px; width: 686.667px; font-size: 13px; color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\"><tbody><tr><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">System</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Length</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Mass</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Time</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Usage</th></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">CGS</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">cm</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">g</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">s</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Older scientific work</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">FPS</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">ft</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">lb</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">s</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">USA, UK (everyday)</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">MKS</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">m</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">kg</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">s</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Basis of SI</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\"><b>SI</b></td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">m</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">kg</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">s (+4 more)</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\"><b>Global standard</b></td></tr></tbody></table><p style=\"margin: 10px 0px 8px; line-height: 1.65; color: rgb(194, 192, 182); font-family: &quot;Anthropic Sans&quot;, sans-serif;\"><b>Seven SI Base Units (2019 redefinition):</b></p><table style=\"margin: 8px 0px 0px; width: 686.667px; font-size: 13px; color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\"><tbody><tr><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Quantity</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Unit</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Symbol</th><th style=\"padding: 6px 10px; text-align: left; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); font-weight: 500; color: rgb(250, 249, 245);\">Modern Definition</th></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Length</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">metre</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">m</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Distance light travels in 1/299,792,458 s</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Mass</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">kilogram</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">kg</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Fixed by Planck constant h</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Time</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">second</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">s</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">9,192,631,770 periods of Cs-133</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Current</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">ampere</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">A</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Fixed by elementary charge e</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Temperature</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">kelvin</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">K</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Fixed by Boltzmann constant k</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">Amount</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">mole</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">mol</td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">6.02214076×10²³ entities</td></tr><tr><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\"><br></td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\"></td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\"></td><td style=\"padding: 6px 10px; border-top: 0.666667px solid rgba(222, 220, 209, 0.15); color: rgb(194, 192, 182);\">540 THz radiation, 683 lm/W<br><br><br><br><br><br><br><p style=\"margin: 10px 0px 8px; font-size: 14px; line-height: 1.65;\"><b>Supplementary Units:</b></p><div class=\"formula\" style=\"margin: 5px 0px; padding: 6px 12px; font-family: ui-monospace, monospace; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 6px; display: inline-block; color: rgb(255, 255, 255);\">Radian (rad): θ = arc/radius = s/r</div><span style=\"color: rgb(255, 255, 255); font-size: medium;\">&nbsp;</span><div class=\"formula\" style=\"margin: 5px 0px; padding: 6px 12px; font-family: ui-monospace, monospace; background: none 0% 0% / auto repeat scroll padding-box border-box rgb(38, 38, 36); border-radius: 6px; display: inline-block; color: rgb(255, 255, 255);\">Steradian (sr): Ω = area/radius² = A/r²</div><span style=\"color: rgb(255, 255, 255); font-size: medium;\"></span><div class=\"warn\" style=\"margin: 6px 0px 0px; padding: 6px 10px; font-size: 12px; border-radius: 6px; background: rgba(255, 243, 205, 0.133); border-left: 3px solid rgb(239, 159, 39);\">⚠ Full circle = 2π rad = 360° &nbsp;|&nbsp; Full sphere = 4π sr</div></td></tr></tbody></table>","color":"#dbeafe","sourceExcerpt":"1.2 Systems of Units","sourcePageNumber":4}},{"id":"e2b67aea-b44c-435c-8241-d111d23f1319","projectId":"265f5a1d-a190-4ee8-bd26-2a4e3ab41fec","documentId":"3dd2901e-cedd-4b9f-bce1-f844fa8f4e9f","type":"note","x":-626.057125,"y":-561.03853125,"width":381.97,"height":171.833,"zIndex":22,"createdAt":1777544041588,"updatedAt":1777544061921,"data":{"type":"note","content":"<p><b style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\">Physical Quantity</b><span style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif; background-color: rgba(230, 241, 251, 0.094);\">&nbsp;— A property that can be measured and expressed as a number with a unit. Every measurement has TWO parts: numerical value (n) × unit (u).</span><br style=\"color: rgb(255, 255, 255); font-family: &quot;Anthropic Sans&quot;, sans-serif;\"><span style=\"font-family: &quot;Anthropic Sans&quot;, sans-serif; color: rgb(194, 192, 182);\">Example: Length of room = 5 m (5 is the number, m is the unit)</span></p>","color":"#dbeafe","sourceExcerpt":"1.1.1 Physical Quantities","sourcePageNumber":2}}]